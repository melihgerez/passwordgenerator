{
  "expo": {
    "name": "PassGen",
    "slug": "PasswordGenerator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "passwordgenerator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1022",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.PasswordGenerator"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/android-icon-background.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A1022",
          "dark": {
            "backgroundColor": "#050913"
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Uygulamaya güvenli giriş için Face ID kullanılır."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab3e3215-48dc-4a93-bc8e-915c2582d397"
      }
    }
  }
}
